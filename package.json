{
  "name": "tiximo",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch bot/api/index.ts",
    "build": "tsc && tsc-alias && vite build bot/web/map",
    "start": "node dist/api/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@clickhouse/client": "^1.18.2",
    "@hono/node-server": "^1.19.11",
    "@napi-rs/canvas": "^0.1.65",
    "@sentry/node": "^8.49.0",
    "@upstash/redis": "^1.34.3",
    "date-fns": "^4.1.0",
    "discord.js": "^14.17.3",
    "drizzle-orm": "^0.40.0",
    "grammy": "^1.34.0",
    "h3-js": "^4.1.0",
    "hono": "^4.7.4",
    "ky": "^1.7.4",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "leaflet": "^1.9.4",
    "ws": "^8.19.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.9",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  }
}
