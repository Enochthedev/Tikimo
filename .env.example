# ─── Platforms ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=                     # openrouter.ai — routes to Claude/Gemini

# ─── Event APIs ──────────────────────────────────────────────────────────────
TICKETMASTER_API_KEY=                   # developer.ticketmaster.com
EVENTBRITE_API_KEY=                     # eventbrite.com/platform

# ─── Event Sources (optional — enable via feature flags) ─────────────────────
PREDICTHQ_API_KEY=                      # predicthq.com — global event intelligence
SERPAPI_KEY=                            # serpapi.com — Google Events fallback (universal)
SKIDDLE_API_KEY=                        # skiddle.com — UK nightlife/music
DICE_API_KEY=                           # dice.fm/partners — UK/EU nightlife

# ─── Maps ────────────────────────────────────────────────────────────────────
GEOAPIFY_API_KEY=                       # geoapify.com — geocoding + reverse geocoding

# ─── Neon (primary DB) ───────────────────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/tiximo?sslmode=require

# ─── ClickHouse Cloud (analytics warehouse) ──────────────────────────────────
CLICKHOUSE_HOST=https://xxx.clickhouse.cloud
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=tiximo

# ─── Cloudflare R2 (object storage) ─────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tiximo-data
R2_TOKEN_VALUE=

# ─── Infrastructure ──────────────────────────────────────────────────────────
UPSTASH_REDIS_URL=                      # upstash.com — Redis for caching + context
UPSTASH_REDIS_TOKEN=

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL=https://your-app.railway.app
WEBHOOK_SECRET=                         # random hex — used to verify Telegram webhook
CRON_SECRET=                            # random hex — used to secure cron endpoints
PORT=3000
NODE_ENV=development

# ─── Heatmap Augmentation ────────────────────────────────────────────────────
HEATMAP_AUGMENTATION=true               # blend external signals into heatmap
HEATMAP_AUGMENTATION_THRESHOLD=100     # min own interactions before blending
SONGKICK_API_KEY=
BANDSINTOWN_APP_ID=

# ─── Feature Flags (override defaults in flags.ts) ───────────────────────────
# These are set in code — listed here for Railway env var reference only
# LIFE_OF_PARTY=false
# SERPAPI_EVENTS=false
# PREDICTHQ_EVENTS=true
# PAGINATION=true
# DISLIKE_SIGNALS=true
