---
import '../styles/global.css'

export interface Props {
  title?: string
  description?: string
}
const {
  title = 'Tiximo — Find your scene.',
  description = 'Events near you, found and booked without leaving your chat app.',
} = Astro.props
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <!-- Boxing (stats/tunnel) + Satoshi (headings/body) -->
  <link href="https://api.fontshare.com/v2/css?f[]=boxing@400,satoshi@900,700,500,400&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
