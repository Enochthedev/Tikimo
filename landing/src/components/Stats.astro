  .sw-bar:nth-child(29) { height: 12px; animation-delay: 0.96s; --col: #ffc200; background: var(--col); }
  .sw-bar:nth-child(30) { height: 28px; animation-delay: 0.03s; --col: #ff9500; background: var(--col); }
  .sw-bar:nth-child(31) { height: 22px; animation-delay: 0.10s; --col: #FF6B00; background: var(--col); }
