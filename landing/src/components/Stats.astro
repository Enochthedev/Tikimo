  .sw-bar:nth-child(37) { height: 28px; animation-delay: 0.52s; --col: #ff2d6b; background: var(--col); }
  .sw-bar:nth-child(38) { height: 8px;  animation-delay: 0.59s; --col: #ff2d6b; background: var(--col); }
  .sw-bar:nth-child(39) { height: 22px; animation-delay: 0.66s; --col: #ff9500; background: var(--col); }
  .sw-bar:nth-child(40) { height: 14px; animation-delay: 0.73s; --col: #ffc200; background: var(--col); }
  .sw-bar:nth-child(41) { height: 30px; animation-delay: 0.80s; --col: #FF6B00; background: var(--col); }
  .sw-bar:nth-child(42) { height: 20px; animation-delay: 0.87s; --col: #FFAA3C; background: var(--col); }
  .sw-bar:nth-child(43) { height: 26px; animation-delay: 0.94s; --col: #FF6B00; background: var(--col); }
  .sw-bar:nth-child(44) { height: 32px; animation-delay: 0.01s; --col: #00e5ff; background: var(--col); }
