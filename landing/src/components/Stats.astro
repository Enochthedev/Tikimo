<section class="stats" aria-label="Platform stats">
  <div class="stats-outer">
    <div class="stats-track">

      <!-- Set 1 -->
      <div class="stat-item">
        <span class="stat-num" style="--col:#FF6B00">2</span>
        <span class="stat-label" style="--col:#FF6B00">CHAT<br>PLATFORMS</span>
      </div>
      <span class="stat-div" style="--col:#FF6B00">/</span>

      <div class="stat-item">
        <span class="stat-num" style="--col:#00e5ff">0</span>
        <span class="stat-label" style="--col:#00e5ff">DOWNLOADS<br>NEEDED</span>
      </div>
      <span class="stat-div" style="--col:#00e5ff">/</span>

      <div class="stat-item">
        <span class="stat-num" style="--col:#ff2d6b">1</span>
        <span class="stat-label" style="--col:#ff2d6b">TAP<br>TO BOOK</span>
      </div>
      <span class="stat-div" style="--col:#ff2d6b">/</span>

      <div class="stat-item">
        <span class="stat-num" style="--col:#FFAA3C">∞</span>
        <span class="stat-label" style="--col:#FFAA3C">EVENTS<br>NEAR YOU</span>
      </div>
      <span class="stat-div" style="--col:#FFAA3C">/</span>

      <div class="stat-item">
        <span class="stat-num" style="--col:#ff9500">AI</span>
        <span class="stat-label" style="--col:#ff9500">POWERED<br>DISCOVERY</span>
      </div>
      <span class="stat-div" style="--col:#ff9500">/</span>

      <!-- Set 2 — duplicate for seamless loop -->
      <div class="stat-item">
        <span class="stat-num" style="--col:#FF6B00">2</span>
        <span class="stat-label" style="--col:#FF6B00">CHAT<br>PLATFORMS</span>
      </div>
      <span class="stat-div" style="--col:#FF6B00">/</span>

      <div class="stat-item">
        <span class="stat-num" style="--col:#00e5ff">0</span>
        <span class="stat-label" style="--col:#00e5ff">DOWNLOADS<br>NEEDED</span>
      </div>
      <span class="stat-div" style="--col:#00e5ff">/</span>

      <div class="stat-item">
        <span class="stat-num" style="--col:#ff2d6b">1</span>
        <span class="stat-label" style="--col:#ff2d6b">TAP<br>TO BOOK</span>
      </div>
      <span class="stat-div" style="--col:#ff2d6b">/</span>

      <div class="stat-item">
        <span class="stat-num" style="--col:#FFAA3C">∞</span>
        <span class="stat-label" style="--col:#FFAA3C">EVENTS<br>NEAR YOU</span>
      </div>
      <span class="stat-div" style="--col:#FFAA3C">/</span>

      <div class="stat-item">
        <span class="stat-num" style="--col:#ff9500">AI</span>
        <span class="stat-label" style="--col:#ff9500">POWERED<br>DISCOVERY</span>
      </div>
      <span class="stat-div" style="--col:#ff9500">/</span>

    </div>
  </div>
</section>

<style>
  /* ── Soundwave strip ── */
  .soundwave-strip {
    background: #000;
    border-top: 1px solid #111;
    padding: 18px 0 0;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    height: 52px;
  }

  .sw-bars {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 32px;
  }

  .sw-bar {
    display: block;
    width: 3px;
    border-radius: 2px;
    background: var(--accent);
    animation: sw-pulse 0.9s ease-in-out infinite alternate;
    min-height: 4px;
  }

  /* Give each bar a different height + delay to simulate audio waveform */
  .sw-bar:nth-child(1)  { height: 8px;  animation-delay: 0.00s; --col: #FF6B00; background: var(--col); }
  .sw-bar:nth-child(2)  { height: 18px; animation-delay: 0.07s; --col: #FF6B00; background: var(--col); }
  .sw-bar:nth-child(3)  { height: 28px; animation-delay: 0.14s; --col: #FF6B00; background: var(--col); }
  .sw-bar:nth-child(4)  { height: 14px; animation-delay: 0.21s; --col: #FF6B00; background: var(--col); }
  .sw-bar:nth-child(5)  { height: 22px; animation-delay: 0.28s; --col: #FF8C00; background: var(--col); }
  .sw-bar:nth-child(6)  { height: 32px; animation-delay: 0.35s; --col: #FFAA3C; background: var(--col); }
  .sw-bar:nth-child(7)  { height: 20px; animation-delay: 0.42s; --col: #FF2D6B; background: var(--col); }
  .sw-bar:nth-child(8)  { height: 26px; animation-delay: 0.49s; --col: #FF2D6B; background: var(--col); }
  .sw-bar:nth-child(9)  { height: 32px; animation-delay: 0.56s; --col: #ff2d6b; background: var(--col); }
  .sw-bar:nth-child(10) { height: 24px; animation-delay: 0.63s; --col: #ff2d6b; background: var(--col); }
  .sw-bar:nth-child(11) { height: 30px; animation-delay: 0.70s; --col: #ff5c38; background: var(--col); }
  .sw-bar:nth-child(12) { height: 18px; animation-delay: 0.77s; --col: #ff9500; background: var(--col); }
  .sw-bar:nth-child(13) { height: 26px; animation-delay: 0.84s; --col: #ff9500; background: var(--col); }
  .sw-bar:nth-child(14) { height: 32px; animation-delay: 0.91s; --col: #ffc200; background: var(--col); }
  .sw-bar:nth-child(15) { height: 20px; animation-delay: 0.98s; --col: #00e5ff; background: var(--col); }
  .sw-bar:nth-child(16) { height: 28px; animation-delay: 0.05s; --col: #00e5ff; background: var(--col); }
  .sw-bar:nth-child(17) { height: 16px; animation-delay: 0.12s; --col: #00E5FF; background: var(--col); }
  .sw-bar:nth-child(18) { height: 32px; animation-delay: 0.19s; --col: #00e5ff; background: var(--col); }
  .sw-bar:nth-child(19) { height: 22px; animation-delay: 0.26s; --col: #00E5FF; background: var(--col); }
  .sw-bar:nth-child(20) { height: 28px; animation-delay: 0.33s; --col: #00e5ff; background: var(--col); }
  .sw-bar:nth-child(21) { height: 14px; animation-delay: 0.40s; --col: #00c4ff; background: var(--col); }
  .sw-bar:nth-child(22) { height: 32px; animation-delay: 0.47s; --col: #FF6B00; background: var(--col); }
  .sw-bar:nth-child(23) { height: 24px; animation-delay: 0.54s; --col: #FFAA3C; background: var(--col); }
