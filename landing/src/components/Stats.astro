  .sw-bar:nth-child(53) { height: 14px; animation-delay: 0.64s; --col: #00e5ff; background: var(--col); }
  .sw-bar:nth-child(54) { height: 28px; animation-delay: 0.71s; --col: #00e5ff; background: var(--col); }
  .sw-bar:nth-child(55) { height: 20px; animation-delay: 0.78s; --col: #00E5FF; background: var(--col); }
  .sw-bar:nth-child(56) { height: 32px; animation-delay: 0.85s; --col: #ff2d6b; background: var(--col); }
  .sw-bar:nth-child(57) { height: 26px; animation-delay: 0.92s; --col: #ff2d6b; background: var(--col); }
  .sw-bar:nth-child(58) { height: 18px; animation-delay: 0.09s; --col: #ff5c38; background: var(--col); }
  .sw-bar:nth-child(59) { height: 30px; animation-delay: 0.16s; --col: #ff9500; background: var(--col); }
  .sw-bar:nth-child(60) { height: 10px; animation-delay: 0.23s; --col: #ffc200; background: var(--col); }

  @keyframes sw-pulse {
    from { transform: scaleY(0.25); opacity: 0.5; }
    to   { transform: scaleY(1);    opacity: 1; }
  }

  /* ── Stats marquee ── */
  .stats {
    background: #000;
    border-bottom: 1px solid #111;
    overflow: hidden;
    padding: 0;
  }

  /* Fade edges */
  .stats::before,
  .stats::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 160px;
    z-index: 2;
    pointer-events: none;
  }
  .stats::before { left: 0;  background: linear-gradient(to right, #000, transparent); }
  .stats::after  { right: 0; background: linear-gradient(to left,  #000, transparent); }

  .stats-outer { overflow: hidden; }

  .stats-track {
    display: flex;
    align-items: flex-end;
    width: max-content;
    animation: marquee-scroll 32s linear infinite;
    padding: 40px 0 48px;
    gap: 0;
  }

  .stats-track:hover { animation-play-state: paused; }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Each stat ── */
  .stat-item {
    display: flex;
    align-items: flex-end;
    gap: 18px;
    padding: 0 20px;
  }

  .stat-num {
    font-family: var(--font-tunnel);
    font-size: clamp(140px, 20vw, 260px);
    font-weight: 400;
    line-height: 0.82;
    letter-spacing: -6px;
    color: var(--col);
    display: block;
    text-shadow:
      0 0  20px color-mix(in srgb, var(--col) 80%, transparent),
      0 0  60px color-mix(in srgb, var(--col) 45%, transparent),
      0 0 120px color-mix(in srgb, var(--col) 20%, transparent),
      4px 6px 0 rgba(0,0,0,0.6);
  }

  .stat-label {
    font-family: var(--font-tunnel);
    font-size: clamp(11px, 1.2vw, 16px);
    font-weight: 400;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--col) 60%, white);
    line-height: 1.5;
    padding-bottom: 18px;
    max-width: 130px;
    opacity: 0.8;
  }

  .stat-div {
    font-family: var(--font-tunnel);
    font-size: clamp(70px, 10vw, 160px);
    font-weight: 400;
    line-height: 0.82;
    color: var(--col);
    opacity: 0.15;
    padding: 0 4px;
    align-self: flex-end;
    padding-bottom: 10px;
  }
</style>
