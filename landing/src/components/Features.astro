---
---

<!-- Wave into features section -->
<div class="wave-divider" aria-hidden="true">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="#0d0009"/>
  </svg>
</div>

<section class="features">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">What Tiximo does</span>
      <h2 class="section-title">Built for the night<br />you actually want.</h2>
    </div>

    <div class="features-grid">
      <div class="feature-card" data-feature>
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3 class="feature-title">Geo-smart search</h3>
        <p class="feature-body">Results from Ticketmaster + Eventbrite, filtered to your exact location.</p>
      </div>

      <div class="feature-card" data-feature>
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 014 4c0 1.95-1.4 3.59-3.25 3.93L12 22l-.75-12.07A4.001 4.001 0 0112 2z"/><path d="M8.5 8.5L4 12l4.5 3.5"/><path d="M15.5 8.5L20 12l-4.5 3.5"/></svg>
        </div>
        <h3 class="feature-title">AI that sounds human</h3>
        <p class="feature-body">Tiximo writes every pitch itself. No copy-paste descriptions.</p>
      </div>

      <div class="feature-card" data-feature>
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="3"/><path d="M2 10h20"/><circle cx="15" cy="4" r="2" fill="var(--bg)" stroke="var(--bg)"/><circle cx="15" cy="20" r="2" fill="var(--bg)" stroke="var(--bg)"/><line x1="15" y1="6" x2="15" y2="18" stroke-dasharray="3 2" opacity="0.5"/></svg>
        </div>
        <h3 class="feature-title">One tap to book</h3>
        <p class="feature-body">Deep link to checkout. No new accounts.</p>
      </div>

      <div class="feature-card" data-feature>
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c1.5 2.5 3 5.5 3 8a3 3 0 01-6 0c0-2.5 1.5-5.5 3-8z"/><path d="M8 16c-2.5 1-4 2.5-4 4h16c0-1.5-1.5-3-4-4"/><path d="M12 12v4"/></svg>
        </div>
        <h3 class="feature-title">Live hype map</h3>
        <p class="feature-body">See what's heating up in real time.</p>
      </div>

      <div class="feature-card" data-feature>
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><circle cx="15.5" cy="8.5" r="1.5"/><circle cx="8.5" cy="15.5" r="1.5"/><circle cx="15.5" cy="15.5" r="1.5"/><circle cx="12" cy="12" r="1.5"/></svg>
        </div>
        <h3 class="feature-title">Feeling Lucky</h3>
        <p class="feature-body">Can't decide? Tiximo picks one and stands behind it.</p>
      </div>

      <div class="feature-card" data-feature>
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/><line x1="9" y1="10" x2="15" y2="10"/></svg>
        </div>
        <h3 class="feature-title">Telegram &amp; WhatsApp</h3>
        <p class="feature-body">Works wherever you already are.</p>
      </div>
    </div>
  </div>
</section>

<!-- Wave out -->
<div class="wave-divider wave-out" aria-hidden="true">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="#080808"/>
  </svg>
</div>

<style>
  .features {
    background: #0d0009;
    padding: 80px 0;
  }

  .wave-divider {
    background: #080808;
    line-height: 0;
  }

  .wave-out {
    background: #0d0009;
  }

  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-title {
    color: var(--text);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
  }

  .feature-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
    transition: border-color 0.3s ease, transform 0.3s ease;
    opacity: 0;
    transform: translateY(30px);
  }

  .feature-card:hover {
    border-color: rgba(255, 69, 0, 0.35);
    transform: translateY(-4px) !important;
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 69, 0, 0.1);
    border: 1px solid rgba(255, 69, 0, 0.2);
    border-radius: 12px;
    color: var(--fire);
    margin-bottom: 16px;
  }

  .feature-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 8px;
    letter-spacing: -0.2px;
  }

  .feature-body {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  gsap.utils.toArray<HTMLElement>('[data-feature]').forEach((card, i) => {
    gsap.to(card, {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: 'power2.out',
      delay: i * 0.1,
      scrollTrigger: {
        trigger: card,
        start: 'top 88%',
        once: true,
      },
    })
  })
</script>
