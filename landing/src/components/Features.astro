---
---
<section class="features" id="features">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Features</span>
      <h2 class="section-title">Built for the night<br />you actually want.</h2>
    </div>

    <div class="features-grid">
      <div class="feature" data-feature>
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3 class="feature-title">Geo-smart search</h3>
        <p class="feature-body">Results from Ticketmaster + Eventbrite, filtered to your exact location.</p>
      </div>

      <div class="feature" data-feature>
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 014 4c0 1.95-1.4 3.59-3.25 3.93L12 22l-.75-12.07A4.001 4.001 0 0112 2z"/><path d="M8.5 8.5L4 12l4.5 3.5"/><path d="M15.5 8.5L20 12l-4.5 3.5"/></svg>
        </div>
        <h3 class="feature-title">AI that sounds human</h3>
        <p class="feature-body">Every pitch is written fresh. No copy-paste descriptions.</p>
      </div>

      <div class="feature" data-feature>
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="3"/><path d="M2 10h20"/></svg>
        </div>
        <h3 class="feature-title">One tap to book</h3>
        <p class="feature-body">Deep link to checkout. No new accounts.</p>
      </div>

      <div class="feature" data-feature>
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c1.5 2.5 3 5.5 3 8a3 3 0 01-6 0c0-2.5 1.5-5.5 3-8z"/><path d="M8 16c-2.5 1-4 2.5-4 4h16c0-1.5-1.5-3-4-4"/><path d="M12 12v4"/></svg>
        </div>
        <h3 class="feature-title">Live hype map</h3>
        <p class="feature-body">See what's heating up in real time across the city.</p>
      </div>

      <div class="feature" data-feature>
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><circle cx="15.5" cy="8.5" r="1.5"/><circle cx="8.5" cy="15.5" r="1.5"/><circle cx="15.5" cy="15.5" r="1.5"/><circle cx="12" cy="12" r="1.5"/></svg>
        </div>
        <h3 class="feature-title">Feeling Lucky</h3>
        <p class="feature-body">Can't decide? Tiximo picks one and stands behind it.</p>
      </div>

      <div class="feature" data-feature>
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/><line x1="9" y1="10" x2="15" y2="10"/></svg>
        </div>
        <h3 class="feature-title">Telegram &amp; WhatsApp</h3>
        <p class="feature-body">Works wherever you already are.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--bg);
    padding: 160px 0;
  }

  .section-header {
    margin-bottom: 72px;
  }

  .section-title {
    color: var(--text);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  @media (max-width: 860px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 520px) {
    .features-grid { grid-template-columns: 1fr; }
  }

  .feature {
    background: var(--bg);
    padding: 36px 32px;
    opacity: 0;
    transform: translateY(20px);
    transition: background 0.3s;
  }

  .feature:hover {
    background: var(--surface);
  }

  .feature-icon {
    color: var(--accent);
    margin-bottom: 20px;
    opacity: 0.8;
  }

  .feature-title {
    font-family: var(--font-heading);
    font-size: 17px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 8px;
  }

  .feature-body {
    font-size: 14px;
    color: var(--dim);
    line-height: 1.6;
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  gsap.utils.toArray<HTMLElement>('[data-feature]').forEach((card, i) => {
    gsap.to(card, {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: 'power2.out',
      delay: i * 0.06,
      scrollTrigger: {
        trigger: card,
        start: 'top 90%',
        once: true,
      },
    })
  })
</script>
