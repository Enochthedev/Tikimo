---
---
<section class="features" id="features">
  <!-- Pilowlava ghost word — decorative, nightlife energy -->
  <div class="features-ghost" aria-hidden="true">TONIGHT</div>

  <div class="container">
    <div class="section-header">
      <span class="section-label">Features</span>
      <h2 class="section-title">Built for the night<br />you actually want.</h2>
    </div>

    <div class="features-grid">

      <div class="feature" data-feature>
        <div class="feature-icon-wrap">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3 class="feature-title">Geo-smart search</h3>
        <p class="feature-body">Results from Ticketmaster + Eventbrite, filtered to your exact location.</p>
      </div>

      <div class="feature" data-feature>
        <div class="feature-icon-wrap">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <h3 class="feature-title">AI that sounds human</h3>
        <p class="feature-body">Every pitch is written fresh. No copy-paste descriptions.</p>
      </div>

      <div class="feature" data-feature>
        <div class="feature-icon-wrap">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="3"/><path d="M2 10h20"/></svg>
        </div>
        <h3 class="feature-title">One tap to book</h3>
        <p class="feature-body">Deep link to checkout. No new accounts.</p>
      </div>

      <div class="feature" data-feature>
        <div class="feature-icon-wrap">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
        </div>
        <h3 class="feature-title">Live hype map</h3>
        <p class="feature-body">See what's heating up in real time across the city.</p>
      </div>

      <div class="feature" data-feature>
        <div class="feature-icon-wrap">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
        <h3 class="feature-title">Feeling Lucky</h3>
        <p class="feature-body">Can't decide? Tiximo picks one and stands behind it.</p>
      </div>

      <div class="feature" data-feature>
        <div class="feature-icon-wrap">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        </div>
        <h3 class="feature-title">Telegram &amp; WhatsApp</h3>
        <p class="feature-body">Works wherever you already are.</p>
      </div>

    </div>
  </div>
</section>

<style>
  .features {
    background: var(--bg);
    padding: 160px 0;
    position: relative;
    overflow: hidden;
  }

  .features-ghost {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-size: clamp(100px, 20vw, 260px);
    font-weight: 400;
    letter-spacing: -4px;
    white-space: nowrap;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 107, 0, 0.07);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .container { position: relative; z-index: 1; }

  .section-header { margin-bottom: 72px; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  @media (max-width: 860px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .features-grid { grid-template-columns: 1fr; } }

  .feature {
    background: var(--bg);
    padding: 36px 32px;
    opacity: 0;
    transform: translateY(20px);
    transition: background 0.35s;
    position: relative;
  }

  .feature::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 20%, var(--a08) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.35s;
    pointer-events: none;
  }

  .feature:hover { background: var(--surface); }
  .feature:hover::after { opacity: 1; }

  .feature-icon-wrap {
    width: 44px; height: 44px;
    border-radius: 12px;
    background: var(--a10);
    border: 1px solid var(--a20);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px;
    color: var(--accent-2);
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .feature:hover .feature-icon-wrap {
    background: var(--a20);
    border-color: var(--a40);
    box-shadow: 0 0 20px var(--a20);
  }

  .feature-title {
    font-family: var(--font-heading);
    font-size: 17px; font-weight: 700;
    color: var(--text); margin-bottom: 8px; letter-spacing: -0.3px;
  }

  .feature-body { font-size: 14px; color: var(--dim); line-height: 1.65; }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  gsap.utils.toArray<HTMLElement>('[data-feature]').forEach((card, i) => {
    gsap.to(card, {
      opacity: 1, y: 0, duration: 0.65, ease: 'power2.out', delay: i * 0.07,
      scrollTrigger: { trigger: card, start: 'top 90%', once: true },
    })
  })
</script>
