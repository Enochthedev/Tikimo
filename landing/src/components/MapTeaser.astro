---
---
<section class="map-teaser">
  <div class="container">
    <div class="map-card" data-map-card>
      <div class="canvas-wrap">
        <canvas id="map-canvas" width="900" height="380"></canvas>
        <div class="map-badge"><span class="live-dot"></span> Live tonight</div>
      </div>

      <div class="map-info">
        <h2 class="section-title">The energy map.</h2>
        <p class="map-body">
          See which parts of the city are heating up. Ghost zones show where demand exists but nothing's been booked yet. Telegram users get the full live version.
        </p>
        <a href="https://t.me/tiximo_bot" class="btn btn-fire">Try it</a>
      </div>
    </div>
  </div>
</section>

<style>
  .map-teaser {
    background: #080808;
    padding: 80px 0;
  }

  .map-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    opacity: 0;
    transform: translateY(40px);
  }

  .canvas-wrap {
    position: relative;
    width: 100%;
    background: #0a0a0a;
    overflow: hidden;
  }

  #map-canvas {
    display: block;
    width: 100%;
    height: auto;
    max-height: 380px;
    object-fit: cover;
  }

  .map-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(0, 0, 0, 0.75);
    border: 1px solid rgba(255, 69, 0, 0.4);
    border-radius: 100px;
    padding: 6px 14px;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--fire);
    box-shadow: 0 0 8px var(--fire);
    animation: blink-dot 1.5s ease-in-out infinite;
  }

  @keyframes blink-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .map-info {
    padding: 40px 40px 48px;
    max-width: 560px;
  }

  .section-title {
    color: var(--text);
    margin-bottom: 16px;
  }

  .map-body {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 28px;
  }

  @media (max-width: 600px) {
    .map-info {
      padding: 28px 24px 36px;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  ScrollTrigger.create({
    trigger: '[data-map-card]',
    start: 'top 80%',
    once: true,
    onEnter: () => {
      gsap.to('[data-map-card]', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power2.out',
      })
    },
  })

  // ─── Canvas Heatmap ─────────────────────────────────────────────────────────
  const canvas = document.getElementById('map-canvas') as HTMLCanvasElement
  const ctx = canvas?.getContext('2d')

  if (ctx) {
    const W = canvas.width
    const H = canvas.height

    // 8 heatmap blobs with x, y, radius, score (0-1), phase offset
    const blobs = [
      { x: 0.15, y: 0.35, r: 0.18, score: 0.9,  phase: 0 },
      { x: 0.38, y: 0.55, r: 0.14, score: 0.6,  phase: 1.2 },
      { x: 0.55, y: 0.25, r: 0.20, score: 0.85, phase: 0.4 },
      { x: 0.70, y: 0.65, r: 0.12, score: 0.45, phase: 2.1 },
      { x: 0.82, y: 0.30, r: 0.16, score: 0.72, phase: 0.9 },
      { x: 0.28, y: 0.80, r: 0.10, score: 0.30, phase: 1.7 },
      { x: 0.62, y: 0.50, r: 0.09, score: 0.55, phase: 3.0 },
      { x: 0.88, y: 0.72, r: 0.13, score: 0.40, phase: 2.5 },
    ]

    let animId: number
    let t = 0

    function draw() {
      ctx.clearRect(0, 0, W, H)

      // Dark background
      ctx.fillStyle = '#0a0a0a'
      ctx.fillRect(0, 0, W, H)

      // Grid lines
      ctx.strokeStyle = 'rgba(255,255,255,0.04)'
      ctx.lineWidth = 1

      const cols = 20
      const rows = 10
      for (let i = 0; i <= cols; i++) {
        const x = (i / cols) * W
        ctx.beginPath()
        ctx.moveTo(x, 0)
        ctx.lineTo(x, H)
        ctx.stroke()
      }
      for (let j = 0; j <= rows; j++) {
        const y = (j / rows) * H
        ctx.beginPath()
        ctx.moveTo(0, y)
        ctx.lineTo(W, y)
        ctx.stroke()
      }

      // Heatmap blobs
      for (const blob of blobs) {
        const pulse = 1 + 0.12 * Math.sin(t * 0.04 + blob.phase)
        const bx = blob.x * W
        const by = blob.y * H
        const br = blob.r * Math.min(W, H) * pulse

        const alpha = blob.score * (0.85 + 0.15 * Math.sin(t * 0.03 + blob.phase))

        // Outer glow
        const grad = ctx.createRadialGradient(bx, by, 0, bx, by, br)

        if (blob.score > 0.7) {
          // Hot — fire orange
          grad.addColorStop(0, `rgba(255, 69, 0, ${alpha * 0.85})`)
          grad.addColorStop(0.4, `rgba(255, 140, 0, ${alpha * 0.5})`)
          grad.addColorStop(0.8, `rgba(255, 200, 0, ${alpha * 0.15})`)
          grad.addColorStop(1, 'rgba(255, 69, 0, 0)')
        } else if (blob.score > 0.4) {
          // Warm
          grad.addColorStop(0, `rgba(255, 140, 0, ${alpha * 0.7})`)
          grad.addColorStop(0.5, `rgba(255, 69, 0, ${alpha * 0.3})`)
          grad.addColorStop(1, 'rgba(255, 69, 0, 0)')
        } else {
          // Ghost zone — dim blue/purple
          grad.addColorStop(0, `rgba(140, 80, 200, ${alpha * 0.5})`)
          grad.addColorStop(0.5, `rgba(100, 60, 180, ${alpha * 0.2})`)
          grad.addColorStop(1, 'rgba(100, 60, 180, 0)')
        }

        ctx.beginPath()
        ctx.arc(bx, by, br, 0, Math.PI * 2)
        ctx.fillStyle = grad
        ctx.fill()

        // Center dot
        ctx.beginPath()
        ctx.arc(bx, by, 3, 0, Math.PI * 2)
        ctx.fillStyle = blob.score > 0.4 ? `rgba(255,200,100,${alpha})` : `rgba(180,120,255,${alpha * 0.8})`
        ctx.fill()
      }

      t++
      animId = requestAnimationFrame(draw)
    }

    draw()

    // Pause when not visible
    const obs = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          if (!animId) draw()
        } else {
          cancelAnimationFrame(animId)
          animId = 0
        }
      }
    })
    obs.observe(canvas)
  }
</script>
