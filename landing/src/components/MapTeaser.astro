---
---
<section class="map-teaser">
  <div class="container">
    <div class="map-layout">
      <div class="map-text" data-map-text>
        <span class="section-label">Explore</span>
        <h2 class="section-title">The energy map.</h2>
        <p class="map-body">
          See which parts of the city are heating up. Ghost zones show where demand exists but nothing's been booked yet.
        </p>
        <a href="https://t.me/tiximo_bot" class="btn btn-primary">See it live</a>
      </div>

      <div class="map-visual" data-map-card>
        <canvas id="map-canvas" width="900" height="440"></canvas>
        <div class="map-badge"><span class="live-dot"></span> Live tonight</div>
      </div>
    </div>
  </div>
</section>

<style>
  .map-teaser {
    background: var(--surface);
    padding: 160px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .map-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 64px;
    align-items: center;
  }

  @media (max-width: 860px) {
    .map-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  .map-text {
    opacity: 0;
    transform: translateY(24px);
  }

  .section-title {
    color: var(--text);
    margin-bottom: 20px;
  }

  .map-body {
    font-size: 16px;
    color: var(--dim);
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 360px;
  }

  .map-visual {
    position: relative;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    opacity: 0;
    transform: translateY(24px);
  }

  #map-canvas {
    display: block;
    width: 100%;
    height: auto;
  }

  .map-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(11, 11, 13, 0.85);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
    animation: blink-dot 2s ease-in-out infinite;
  }

  @keyframes blink-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  ScrollTrigger.create({
    trigger: '[data-map-text]',
    start: 'top 80%',
    once: true,
    onEnter: () => {
      gsap.to('[data-map-text]', { opacity: 1, y: 0, duration: 0.9, ease: 'power2.out' })
    },
  })

  ScrollTrigger.create({
    trigger: '[data-map-card]',
    start: 'top 80%',
    once: true,
    onEnter: () => {
      gsap.to('[data-map-card]', { opacity: 1, y: 0, duration: 0.9, ease: 'power2.out', delay: 0.15 })
    },
  })

  // ─── Canvas Heatmap ─────────────────────────────────────────────────────────
  const canvas = document.getElementById('map-canvas') as HTMLCanvasElement
  const ctx = canvas?.getContext('2d')

  if (ctx) {
    const W = canvas.width
    const H = canvas.height

    const blobs = [
      { x: 0.15, y: 0.35, r: 0.18, score: 0.9,  phase: 0 },
      { x: 0.38, y: 0.55, r: 0.14, score: 0.6,  phase: 1.2 },
      { x: 0.55, y: 0.25, r: 0.20, score: 0.85, phase: 0.4 },
      { x: 0.70, y: 0.65, r: 0.12, score: 0.45, phase: 2.1 },
      { x: 0.82, y: 0.30, r: 0.16, score: 0.72, phase: 0.9 },
      { x: 0.28, y: 0.80, r: 0.10, score: 0.30, phase: 1.7 },
      { x: 0.62, y: 0.50, r: 0.09, score: 0.55, phase: 3.0 },
      { x: 0.88, y: 0.72, r: 0.13, score: 0.40, phase: 2.5 },
    ]

    let animId: number
    let t = 0

    function draw() {
      ctx.clearRect(0, 0, W, H)

      ctx.fillStyle = '#0b0b0d'
      ctx.fillRect(0, 0, W, H)

      // Subtle grid
      ctx.strokeStyle = 'rgba(255,255,255,0.025)'
      ctx.lineWidth = 1
      const cols = 24, rows = 12
      for (let i = 0; i <= cols; i++) {
        const x = (i / cols) * W
        ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke()
      }
      for (let j = 0; j <= rows; j++) {
        const y = (j / rows) * H
        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke()
      }

      for (const blob of blobs) {
        const pulse = 1 + 0.1 * Math.sin(t * 0.035 + blob.phase)
        const bx = blob.x * W
        const by = blob.y * H
        const br = blob.r * Math.min(W, H) * pulse
        const alpha = blob.score * (0.8 + 0.2 * Math.sin(t * 0.025 + blob.phase))

        const grad = ctx.createRadialGradient(bx, by, 0, bx, by, br)

        if (blob.score > 0.7) {
          grad.addColorStop(0, `rgba(212, 88, 58, ${alpha * 0.75})`)
          grad.addColorStop(0.4, `rgba(196, 145, 90, ${alpha * 0.4})`)
          grad.addColorStop(0.8, `rgba(232, 196, 102, ${alpha * 0.12})`)
          grad.addColorStop(1, 'rgba(212, 88, 58, 0)')
        } else if (blob.score > 0.4) {
          grad.addColorStop(0, `rgba(196, 145, 90, ${alpha * 0.6})`)
          grad.addColorStop(0.5, `rgba(212, 88, 58, ${alpha * 0.25})`)
          grad.addColorStop(1, 'rgba(196, 145, 90, 0)')
        } else {
          grad.addColorStop(0, `rgba(120, 90, 160, ${alpha * 0.4})`)
          grad.addColorStop(0.5, `rgba(90, 70, 140, ${alpha * 0.15})`)
          grad.addColorStop(1, 'rgba(90, 70, 140, 0)')
        }

        ctx.beginPath()
        ctx.arc(bx, by, br, 0, Math.PI * 2)
        ctx.fillStyle = grad
        ctx.fill()

        // Center dot
        ctx.beginPath()
        ctx.arc(bx, by, 2.5, 0, Math.PI * 2)
        ctx.fillStyle = blob.score > 0.4 ? `rgba(232,196,102,${alpha})` : `rgba(160,120,220,${alpha * 0.7})`
        ctx.fill()
      }

      t++
      animId = requestAnimationFrame(draw)
    }

    draw()

    const obs = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) { if (!animId) draw() }
        else { cancelAnimationFrame(animId); animId = 0 }
      }
    })
    obs.observe(canvas)
  }
</script>
