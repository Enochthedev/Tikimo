---
---
<section class="cta">
  <div class="cta-inner">
    <div class="cta-title-wrap" data-cta-title>
      <span class="cta-line cta-tonight">Tonight</span>
      <span class="cta-line cta-starts">starts here.</span>
    </div>

    <p class="cta-sub" data-cta-sub>
      Open Tiximo, share your location, pick something good.
    </p>

    <div class="cta-buttons" data-cta-btns>
      <a href="https://t.me/tiximo_bot" class="btn btn-primary">Open in Telegram</a>
      <a href="https://wa.me/tiximo" class="btn btn-outline">WhatsApp</a>
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--bg);
    padding: 180px 28px;
    text-align: center;
  }

  .cta-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-title-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 32px;
    opacity: 0;
    transform: translateY(24px);
  }

  .cta-line {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(48px, 11vw, 100px);
    letter-spacing: -3px;
    line-height: 0.9;
    display: block;
  }

  .cta-tonight {
    color: var(--text);
  }

  .cta-starts {
    background: linear-gradient(135deg, var(--accent), var(--warm), var(--glow));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cta-sub {
    font-size: clamp(15px, 2vw, 18px);
    color: var(--dim);
    margin-bottom: 44px;
    line-height: 1.6;
    opacity: 0;
    transform: translateY(16px);
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(16px);
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  ScrollTrigger.create({
    trigger: '.cta',
    start: 'top 70%',
    once: true,
    onEnter: () => {
      gsap.to('[data-cta-title]', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' })
      gsap.to(['[data-cta-sub]', '[data-cta-btns]'], {
        opacity: 1, y: 0, duration: 0.7, ease: 'power2.out', stagger: 0.15, delay: 0.25,
      })
    },
  })
</script>
