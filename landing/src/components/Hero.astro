---
---
<section class="hero" id="hero">
  <!-- Three.js ember particles -->
  <canvas class="hero-particles" id="hero-particles" aria-hidden="true"></canvas>

  <!-- Subtle grain overlay -->
  <div class="hero-grain" aria-hidden="true"></div>

  <!-- Sticky viewport stage -->
  <div class="hero-stage">
    <!-- Scattered decorative dots -->
    <div class="deco deco-1" aria-hidden="true"></div>
    <div class="deco deco-2" aria-hidden="true"></div>
    <div class="deco deco-3" aria-hidden="true"></div>

    <div class="hero-title-wrap" id="hero-title">
      <span class="hero-line hero-line--wordmark" id="hero-tix">TIX</span>

      <!-- SVG ticket — starts below viewport, flies up on scroll -->
      <div class="hero-ticket" id="hero-ticket" aria-hidden="true">
        <svg viewBox="0 0 240 160" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="ticket-fill" x1="0" y1="0" x2="240" y2="160" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#FF6B35"/>
              <stop offset="50%" stop-color="#FF4500"/>
              <stop offset="100%" stop-color="#FF8C00"/>
            </linearGradient>
            <linearGradient id="ticket-shine" x1="0" y1="0" x2="120" y2="160" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="rgba(255,255,255,0.25)"/>
              <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
            </linearGradient>
            <mask id="ticket-mask">
              <rect width="240" height="160" rx="18" fill="white"/>
              <circle cx="168" cy="0" r="14" fill="black"/>
              <circle cx="168" cy="160" r="14" fill="black"/>
            </mask>
          </defs>
          <!-- Body -->
          <rect width="240" height="160" rx="18" fill="url(#ticket-fill)" mask="url(#ticket-mask)"/>
          <!-- Shine overlay -->
          <rect width="240" height="160" rx="18" fill="url(#ticket-shine)" mask="url(#ticket-mask)" opacity="0.5"/>
          <!-- Perforation -->
          <line x1="168" y1="18" x2="168" y2="142" stroke="rgba(0,0,0,0.15)" stroke-width="1.5" stroke-dasharray="5 4"/>
          <!-- ADMIT ONE -->
          <text x="80" y="62" text-anchor="middle" font-family="'Cabinet Grotesk',system-ui,sans-serif" font-size="20" font-weight="900" fill="rgba(0,0,0,0.6)" letter-spacing="4">ADMIT</text>
          <text x="80" y="92" text-anchor="middle" font-family="'Cabinet Grotesk',system-ui,sans-serif" font-size="20" font-weight="900" fill="rgba(0,0,0,0.6)" letter-spacing="4">ONE</text>
          <!-- Stars -->
          <text x="80" y="122" text-anchor="middle" font-size="12" fill="rgba(0,0,0,0.25)" letter-spacing="6">&#9733; &#9733; &#9733;</text>
          <!-- Stub number -->
          <text transform="rotate(90 202 80)" x="202" y="80" text-anchor="middle" font-family="'Courier New',monospace" font-size="8" fill="rgba(0,0,0,0.2)" letter-spacing="1">No. 01071982</text>
        </svg>
      </div>

      <span class="hero-line hero-line--wordmark" id="hero-imo">IMO</span>
    </div>

    <p class="hero-tagline" id="hero-tagline">
      Tell me where you are.<br />
      <strong>I'll find you something good.</strong>
    </p>

    <div class="hero-cta-row" id="hero-cta">
      <a href="https://t.me/tiximo_bot" class="btn btn-fire">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/></svg>
        Open in Telegram
      </a>
      <a href="https://wa.me/tiximo" class="btn btn-ghost">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a5 5 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
    </div>

    <p class="hero-note" id="hero-note">No app download · No account · Just chat</p>

    <!-- Scroll hint at bottom -->
    <div class="scroll-hint" id="scroll-hint" aria-hidden="true">
      <div class="scroll-hint-line"></div>
    </div>
  </div>
</section>

<style>
  /* Extra height so scroll trigger has room */
  .hero {
    position: relative;
    height: 280vh;
    background: var(--bg);
  }

  /* Three.js canvas - stays in viewport while hero is active */
  .hero-particles {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  /* Noise grain texture */
  .hero-grain {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    transition: opacity 0.5s ease;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px 200px;
  }

  /* Sticky stage — pins to viewport while user scrolls */
  .hero-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px;
    z-index: 2;
    overflow: hidden;
  }

  /* Decorative dots */
  .deco {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .deco-1 {
    width: 6px;
    height: 6px;
    background: var(--fire);
    top: 18%;
    left: 12%;
    opacity: 0.5;
    animation: pulse-deco 3s ease-in-out infinite;
  }

  .deco-2 {
    width: 4px;
    height: 4px;
    background: var(--ember);
    top: 28%;
    right: 15%;
    opacity: 0.4;
    animation: pulse-deco 4s ease-in-out infinite 1s;
  }

  .deco-3 {
    width: 8px;
    height: 8px;
    background: var(--glow);
    bottom: 25%;
    left: 8%;
    opacity: 0.3;
    animation: pulse-deco 5s ease-in-out infinite 0.5s;
  }

  @keyframes pulse-deco {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.6); opacity: 0.6; }
  }

  /* Title block */
  .hero-title-wrap {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    line-height: 0.85;
    margin-bottom: 48px;
    opacity: 0;
  }

  .hero-line {
    font-weight: 900;
    font-size: clamp(110px, 22vw, 240px);
    letter-spacing: -6px;
    line-height: 0.85;
    color: var(--text);
    display: block;
    will-change: transform;
  }

  /* Pilowlava for the wordmark only */
  .hero-line--wordmark {
    font-family: 'Pilowlava', var(--font-display);
    letter-spacing: -2px;
  }

  /* SVG ticket — starts far below, scroll drives it up */
  .hero-ticket {
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(120px, 18vw, 200px);
    z-index: 10;
    filter:
      drop-shadow(0 8px 32px rgba(255, 69, 0, 0.55))
      drop-shadow(0 2px 8px rgba(255, 69, 0, 0.35));
    will-change: transform;
    pointer-events: none;
    /* Initial position: off-screen below — GSAP overrides this */
    transform: translate(-50%, 120vh) rotate(15deg);
    opacity: 0;
  }

  .hero-ticket svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Tagline */
  .hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(18px, 2.5vw, 28px);
    font-weight: 300;
    color: var(--muted);
    line-height: 1.55;
    margin-bottom: 40px;
    letter-spacing: -0.2px;
    opacity: 0;
  }

  .hero-tagline strong {
    color: var(--text);
    font-weight: 600;
  }

  /* CTA row */
  .hero-cta-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 24px;
    opacity: 0;
  }

  .hero-note {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.8px;
    text-transform: uppercase;
    opacity: 0;
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
  }

  .scroll-hint-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, transparent, var(--fire), transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); }
    50% { opacity: 0.8; transform: scaleY(1); }
  }

  /* Responsive */
  @media (max-width: 600px) {
    .hero-line {
      letter-spacing: -3px;
    }
    .hero-ticket {
      width: 100px;
    }
    .deco { display: none; }
  }
</style>

<script>
  import * as THREE from 'three'
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  // ─── Three.js Ember Particles ──────────────────────────────────────────────

  const canvas = document.getElementById('hero-particles') as HTMLCanvasElement
  if (canvas) {
    const scene = new THREE.Scene()
    const w = canvas.clientWidth
    const h = canvas.clientHeight

    const camera = new THREE.PerspectiveCamera(60, w / h, 0.1, 100)
    camera.position.z = 30

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: false,
    })
    renderer.setSize(w, h)
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2))

    // Soft circle texture for particle glow
    const texCanvas = document.createElement('canvas')
    texCanvas.width = 64
    texCanvas.height = 64
    const texCtx = texCanvas.getContext('2d')!
    const grad = texCtx.createRadialGradient(32, 32, 0, 32, 32, 32)
    grad.addColorStop(0, 'rgba(255,255,255,1)')
    grad.addColorStop(0.2, 'rgba(255,255,255,0.8)')
    grad.addColorStop(0.5, 'rgba(255,255,255,0.3)')
    grad.addColorStop(1, 'rgba(255,255,255,0)')
    texCtx.fillStyle = grad
    texCtx.fillRect(0, 0, 64, 64)
    const particleTexture = new THREE.CanvasTexture(texCanvas)

    // Particles
    const isMobile = window.innerWidth < 768
    const count = isMobile ? 100 : 220
    const positions = new Float32Array(count * 3)
    const colors = new Float32Array(count * 3)

    const palette = [
      [1.0, 0.27, 0.0],   // fire
      [1.0, 0.55, 0.0],   // ember
      [1.0, 0.84, 0.0],   // glow
      [1.0, 0.42, 0.21],  // warm
      [1.0, 0.7, 0.4],    // soft
    ]

    const velocitiesY = new Float32Array(count)
    const velocitiesX = new Float32Array(count)

    for (let i = 0; i < count; i++) {
      positions[i * 3]     = (Math.random() - 0.5) * 60
      positions[i * 3 + 1] = (Math.random() - 0.5) * 40
      positions[i * 3 + 2] = (Math.random() - 0.5) * 20

      const c = palette[Math.floor(Math.random() * palette.length)]
      colors[i * 3]     = c[0]
      colors[i * 3 + 1] = c[1]
      colors[i * 3 + 2] = c[2]

      velocitiesY[i] = Math.random() * 0.025 + 0.008
      velocitiesX[i] = (Math.random() - 0.5) * 0.015
    }

    const geometry = new THREE.BufferGeometry()
    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3))
    geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3))

    const material = new THREE.PointsMaterial({
      size: isMobile ? 0.35 : 0.45,
      map: particleTexture,
      vertexColors: true,
      transparent: true,
      opacity: 0.7,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    })

    const points = new THREE.Points(geometry, material)
    scene.add(points)

    let isVisible = true

    function animate() {
      if (!isVisible) return
      requestAnimationFrame(animate)

      const pos = geometry.attributes.position.array as Float32Array
      for (let i = 0; i < count; i++) {
        pos[i * 3] += velocitiesX[i]
        pos[i * 3 + 1] += velocitiesY[i]

        if (pos[i * 3 + 1] > 24) {
          pos[i * 3 + 1] = -24
          pos[i * 3] = (Math.random() - 0.5) * 60
        }
      }
      geometry.attributes.position.needsUpdate = true

      points.rotation.y += 0.00015
      renderer.render(scene, camera)
    }

    animate()

    // Pause when off-screen
    const observer = new IntersectionObserver((entries) => {
      for (const e of entries) {
        isVisible = e.isIntersecting
        if (isVisible) animate()
      }
    })
    observer.observe(canvas)

    // Resize
    window.addEventListener('resize', () => {
      const nw = canvas.clientWidth
      const nh = canvas.clientHeight
      camera.aspect = nw / nh
      camera.updateProjectionMatrix()
      renderer.setSize(nw, nh)
    }, { passive: true })
  }

  // ─── GSAP: Page Load Animation ─────────────────────────────────────────────

  const loadTl = gsap.timeline({ defaults: { ease: 'back.out(1.4)' } })

  // Show the title wrapper
  loadTl.set('#hero-title', { opacity: 1 })

  // TIX drops from above
  loadTl.fromTo('#hero-tix',
    { y: -120, opacity: 0 },
    { y: 0, opacity: 1, duration: 0.9 },
    0.15
  )

  // IMO drops (staggered)
  loadTl.fromTo('#hero-imo',
    { y: -120, opacity: 0 },
    { y: 0, opacity: 1, duration: 0.9 },
    0.3
  )

  // Tagline fades up
  loadTl.fromTo('#hero-tagline',
    { y: 24, opacity: 0 },
    { y: 0, opacity: 1, duration: 0.7, ease: 'power2.out' },
    0.7
  )

  // CTA buttons fade up
  loadTl.fromTo('#hero-cta',
    { y: 20, opacity: 0 },
    { y: 0, opacity: 1, duration: 0.6, ease: 'power2.out' },
    0.85
  )

  // Note fades in
  loadTl.fromTo('#hero-note',
    { opacity: 0 },
    { opacity: 1, duration: 0.5, ease: 'power2.out' },
    1.0
  )

  // Scroll hint fades in
  loadTl.fromTo('#scroll-hint',
    { opacity: 0 },
    { opacity: 1, duration: 0.6, ease: 'power2.out' },
    1.1
  )

  // ─── GSAP: Scroll-Driven Ticket Rise ───────────────────────────────────────
  // Ticket starts far below the viewport and flies up as user scrolls,
  // landing centered over the TIXIMO wordmark.

  const scrollTl = gsap.timeline({
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom bottom',
      scrub: 1,
    },
  })

  // Phase 1 (0–60%): Ticket rises from below, rotating
  scrollTl.fromTo('#hero-ticket',
    { y: '100vh', rotation: 18, scale: 0.5, opacity: 0 },
    { y: '0vh', rotation: -4, scale: 1.05, opacity: 1, ease: 'power2.out' },
    0
  )

  // Phase 2 (60–80%): Ticket eases into final position with a subtle settle
  scrollTl.to('#hero-ticket', {
    y: '-5vh',
    rotation: -8,
    scale: 1,
    ease: 'power1.inOut',
  }, 0.6)

  // Phase 3 (80–100%): Fade out scroll hint
  scrollTl.to('#scroll-hint', {
    opacity: 0,
    duration: 0.2,
  }, 0.2)

  // After scroll completes, gentle floating
  ScrollTrigger.create({
    trigger: '#hero',
    start: 'bottom bottom',
    onEnterBack: () => gsap.killTweensOf('#hero-ticket', 'y,rotation'),
    onLeave: () => {
      gsap.to('#hero-ticket', {
        y: '-5vh',
        rotation: -10,
        duration: 3,
        ease: 'sine.inOut',
        yoyo: true,
        repeat: -1,
      })
    },
  })

  // Fade out particles & grain when leaving hero section
  ScrollTrigger.create({
    trigger: '#hero',
    start: 'bottom 120%',
    end: 'bottom top',
    onLeave: () => {
      gsap.to(['#hero-particles', '.hero-grain'], { opacity: 0, duration: 0.4 })
    },
    onEnterBack: () => {
      gsap.to('#hero-particles', { opacity: 1, duration: 0.4 })
      gsap.to('.hero-grain', { opacity: 0.035, duration: 0.4 })
    },
  })
</script>
