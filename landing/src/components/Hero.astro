---
---
<section class="hero" id="hero">
  <canvas class="hero-canvas" id="hero-canvas" aria-hidden="true"></canvas>

  <div class="hero-stage">
    <div class="hero-center" id="hero-center">
      <h1 class="hero-wordmark" id="hero-wordmark">TIXIMO</h1>

      <!-- SVG ticket — scroll-driven from bottom -->
      <div class="hero-ticket" id="hero-ticket" aria-hidden="true">
        <svg viewBox="0 0 220 148" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="tg" x1="0" y1="0" x2="220" y2="148" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#d4583a"/>
              <stop offset="100%" stop-color="#c4915a"/>
            </linearGradient>
            <mask id="tm">
              <rect width="220" height="148" rx="16" fill="#fff"/>
              <circle cx="154" cy="0" r="12" fill="#000"/>
              <circle cx="154" cy="148" r="12" fill="#000"/>
            </mask>
          </defs>
          <rect width="220" height="148" rx="16" fill="url(#tg)" mask="url(#tm)"/>
          <line x1="154" y1="16" x2="154" y2="132" stroke="rgba(0,0,0,.1)" stroke-width="1.5" stroke-dasharray="4 3"/>
          <text x="72" y="58" text-anchor="middle" font-family="'Cabinet Grotesk',sans-serif" font-size="16" font-weight="800" fill="rgba(0,0,0,.45)" letter-spacing="3">ADMIT</text>
          <text x="72" y="84" text-anchor="middle" font-family="'Cabinet Grotesk',sans-serif" font-size="16" font-weight="800" fill="rgba(0,0,0,.45)" letter-spacing="3">ONE</text>
          <text x="72" y="116" text-anchor="middle" font-size="10" fill="rgba(0,0,0,.15)" letter-spacing="4">&#9733; &#9733; &#9733;</text>
          <text transform="rotate(90 186 74)" x="186" y="74" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(0,0,0,.1)">No. 01071982</text>
        </svg>
      </div>

      <p class="hero-sub" id="hero-sub">
        Events near you, found and booked<br />without leaving your chat app.
      </p>
    </div>

    <div class="hero-actions" id="hero-actions">
      <a href="https://t.me/tiximo_bot" class="btn btn-primary">Open Telegram</a>
      <a href="https://wa.me/tiximo" class="btn btn-outline">WhatsApp</a>
    </div>

    <p class="hero-note" id="hero-note">No download &middot; No account &middot; Just chat</p>

    <div class="hero-scroll" id="hero-scroll" aria-hidden="true">
      <span class="hero-scroll-label">Scroll</span>
      <div class="hero-scroll-bar"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 260vh;
    background: var(--bg);
  }

  .hero-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .hero-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 1;
    padding: 0 28px;
    overflow: hidden;
  }

  .hero-center {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    opacity: 0;
  }

  .hero-wordmark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(64px, 13vw, 180px);
    letter-spacing: -4px;
    line-height: 0.85;
    color: var(--text);
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .hero-ticket {
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(100px, 15vw, 170px);
    z-index: 2;
    pointer-events: none;
    will-change: transform;
    filter: drop-shadow(0 16px 48px rgba(212, 88, 58, 0.3));
    transform: translate(-50%, 110vh) rotate(14deg);
    opacity: 0;
  }

  .hero-ticket svg {
    width: 100%;
    height: auto;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.8vw, 20px);
    font-weight: 400;
    color: var(--dim);
    line-height: 1.7;
    text-align: center;
    max-width: 400px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    margin-top: 12px;
    opacity: 0;
  }

  .hero-note {
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-top: 6px;
    opacity: 0;
  }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
  }

  .hero-scroll-label {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--dim);
  }

  .hero-scroll-bar {
    width: 1px;
    height: 32px;
    background: linear-gradient(to bottom, var(--dim), transparent);
    animation: bar-pulse 3s ease-in-out infinite;
  }

  @keyframes bar-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.4); }
    50% { opacity: 0.8; transform: scaleY(1); }
  }

  @media (max-width: 600px) {
    .hero-wordmark { letter-spacing: -2px; }
    .hero-ticket { width: 80px; }
  }
</style>

<script>
  import * as THREE from 'three'
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  // ─── Particles (warm amber/gold tones) ────────────────────────────────────
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement
  if (canvas) {
    const scene = new THREE.Scene()
    let w = canvas.clientWidth, h = canvas.clientHeight
    const cam = new THREE.PerspectiveCamera(55, w / h, 0.1, 80)
    cam.position.z = 28
    const gl = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: false })
    gl.setSize(w, h)
    gl.setPixelRatio(Math.min(devicePixelRatio, 2))

    const tex = (() => {
      const c = document.createElement('canvas'); c.width = c.height = 64
      const x = c.getContext('2d')!
      const g = x.createRadialGradient(32,32,0,32,32,32)
      g.addColorStop(0,'rgba(255,255,255,1)')
      g.addColorStop(.3,'rgba(255,255,255,.4)')
      g.addColorStop(1,'rgba(255,255,255,0)')
      x.fillStyle = g; x.fillRect(0,0,64,64)
      return new THREE.CanvasTexture(c)
    })()

    const N = innerWidth < 768 ? 60 : 120
    const pos = new Float32Array(N*3), col = new Float32Array(N*3)
    const vy = new Float32Array(N), vx = new Float32Array(N)
    // warm amber / terracotta / gold palette
    const pal = [
      [.83,.35,.23],  // terracotta
      [.77,.57,.35],  // warm sand
      [.91,.77,.40],  // gold
      [.65,.45,.28],  // brown amber
      [.95,.85,.55],  // pale gold
    ]
    for (let i=0;i<N;i++){
      pos[i*3]=(Math.random()-.5)*55; pos[i*3+1]=(Math.random()-.5)*40; pos[i*3+2]=(Math.random()-.5)*20
      const c=pal[Math.random()*pal.length|0]; col[i*3]=c[0]; col[i*3+1]=c[1]; col[i*3+2]=c[2]
      vy[i]=Math.random()*.015+.004; vx[i]=(Math.random()-.5)*.008
    }
    const geo = new THREE.BufferGeometry()
    geo.setAttribute('position', new THREE.BufferAttribute(pos,3))
    geo.setAttribute('color', new THREE.BufferAttribute(col,3))
    const mat = new THREE.PointsMaterial({
      size: innerWidth<768?.25:.35, map:tex, vertexColors:true,
      transparent:true, opacity:.4, blending:THREE.AdditiveBlending, depthWrite:false
    })
    const pts = new THREE.Points(geo,mat); scene.add(pts)
    let vis=true
    function tick(){if(!vis)return; requestAnimationFrame(tick)
      const p=geo.attributes.position.array as Float32Array
      for(let i=0;i<N;i++){p[i*3]+=vx[i];p[i*3+1]+=vy[i];if(p[i*3+1]>22){p[i*3+1]=-22;p[i*3]=(Math.random()-.5)*55}}
      geo.attributes.position.needsUpdate=true; pts.rotation.y+=.00008; gl.render(scene,cam)
    }
    tick()
    new IntersectionObserver(e=>{vis=e[0].isIntersecting;if(vis)tick()}).observe(canvas)
    addEventListener('resize',()=>{w=canvas.clientWidth;h=canvas.clientHeight;cam.aspect=w/h;cam.updateProjectionMatrix();gl.setSize(w,h)},{passive:true})
  }

  // ─── Load animation ────────────────────────────────────────────────────────
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } })
  tl.set('#hero-center', { opacity: 1 })
  tl.fromTo('#hero-wordmark', { y: 50, opacity: 0, scale: .94 }, { y: 0, opacity: 1, scale: 1, duration: 1.2 }, .15)
  tl.fromTo('#hero-sub', { y: 20, opacity: 0 }, { y: 0, opacity: 1, duration: .8 }, .5)
  tl.fromTo('#hero-actions', { y: 14, opacity: 0 }, { y: 0, opacity: 1, duration: .7 }, .65)
  tl.fromTo('#hero-note', { opacity: 0 }, { opacity: 1, duration: .6 }, .8)
  tl.fromTo('#hero-scroll', { opacity: 0 }, { opacity: 1, duration: .6 }, 1)

  // ─── Scroll: ticket rises from below ───────────────────────────────────────
  const st = gsap.timeline({
    scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom bottom', scrub: 1.4 }
  })
  st.fromTo('#hero-ticket',
    { y: '110vh', rotation: 16, scale: .45, opacity: 0 },
    { y: '0vh', rotation: -6, scale: 1.08, opacity: 1, ease: 'power2.out' }, 0)
  st.to('#hero-ticket', { y: '-4vh', rotation: -8, scale: 1, ease: 'power1.inOut' }, .65)
  st.to('#hero-scroll', { opacity: 0 }, .15)

  // Fade particles when leaving hero
  ScrollTrigger.create({
    trigger: '#hero',
    start: 'bottom 100%',
    onLeave: () => gsap.to('#hero-canvas', { opacity: 0, duration: .4 }),
    onEnterBack: () => gsap.to('#hero-canvas', { opacity: 1, duration: .4 }),
  })

  // Gentle float after scroll
  ScrollTrigger.create({
    trigger: '#hero', start: 'bottom bottom',
    onLeave: () => gsap.to('#hero-ticket', { y: '-4vh', rotation: -10, duration: 3.5, ease: 'sine.inOut', yoyo: true, repeat: -1 }),
    onEnterBack: () => gsap.killTweensOf('#hero-ticket', 'y,rotation'),
  })
</script>
