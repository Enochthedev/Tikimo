---
---
<section class="chat-demo">
  <div class="container">
    <div class="chat-grid">

      <div class="chat-text" data-chat-text>
        <span class="section-label">In action</span>
        <h2 class="section-title">Your chat app<br />is the app.</h2>
        <p class="chat-body">No downloads. No new UI to learn. Tiximo lives inside Telegram and WhatsApp — right where you already are.</p>
        <a href="https://t.me/tiximo_bot" class="btn btn-primary">Try Tiximo</a>
      </div>

      <div class="chat-window" data-chat-window>
        <div class="chat-topbar">
          <div class="chat-avatar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><rect x="4" y="4" width="16" height="16" rx="4"/><circle cx="9" cy="11" r="1.5" fill="#fff" stroke="none"/><circle cx="15" cy="11" r="1.5" fill="#fff" stroke="none"/><path d="M9 16c1.5 1 4.5 1 6 0"/></svg>
          </div>
          <div class="chat-meta">
            <span class="chat-name">Tiximo</span>
            <span class="chat-status">online</span>
          </div>
        </div>

        <div class="chat-messages">
          <div class="msg msg-bot" data-msg="0">
            <div class="msg-bubble">
              Hey! Tell me where you are and I'll find you something good tonight.
            </div>
          </div>

          <div class="msg msg-user" data-msg="1">
            <div class="msg-bubble">Brixton, London</div>
          </div>

          <div class="msg msg-bot" data-msg="2">
            <div class="msg-bubble">Found 6 things near you. Here's the standout:</div>
          </div>

          <div class="msg msg-bot msg-card" data-msg="3">
            <div class="msg-bubble msg-event-card">
              <div class="event-title">Hessle Audio @ Corsica Studios</div>
              <div class="event-meta">Tonight &middot; 10 pm – 6 am &middot; Elephant &amp; Castle &middot; £12</div>
              <p class="event-pitch">Four hours of warehouse techno in a room that's been doing this since 2009.</p>
              <a href="#" class="event-book-btn">Book it &rarr;</a>
            </div>
          </div>

          <div class="msg msg-bot" data-msg="4">
            <div class="msg-bubble">Want more options, or should I narrow it down?</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .chat-demo {
    background: var(--surface);
    padding: 160px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .chat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }

  @media (max-width: 860px) {
    .chat-grid {
      grid-template-columns: 1fr;
      gap: 56px;
    }
  }

  .chat-text {
    opacity: 0;
    transform: translateX(-24px);
  }

  .section-title {
    color: var(--text);
    margin-bottom: 24px;
  }

  .chat-body {
    font-size: 16px;
    color: var(--dim);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 380px;
  }

  .chat-window {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    opacity: 0;
    transform: translateX(24px);
  }

  .chat-topbar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
  }

  .chat-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .chat-meta {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .chat-name {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
  }

  .chat-status {
    font-size: 11px;
    color: var(--dim);
  }

  .chat-messages {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .msg {
    display: flex;
    opacity: 0;
    transform: translateY(10px);
  }

  .msg-bot { justify-content: flex-start; }
  .msg-user { justify-content: flex-end; }

  .msg-bubble {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 14px;
    font-size: 14px;
    line-height: 1.55;
  }

  .msg-bot .msg-bubble {
    background: rgba(255, 255, 255, 0.04);
    color: var(--text);
    border-bottom-left-radius: 4px;
  }

  .msg-user .msg-bubble {
    background: var(--accent);
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  .msg-event-card {
    background: rgba(212, 88, 58, 0.06) !important;
    border: 1px solid rgba(212, 88, 58, 0.15);
    max-width: 92% !important;
    padding: 14px 16px !important;
  }

  .event-title {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
  }

  .event-meta {
    font-size: 12px;
    color: var(--dim);
    margin-bottom: 8px;
  }

  .event-pitch {
    font-size: 13px;
    color: var(--dim);
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .event-book-btn {
    display: inline-block;
    padding: 6px 14px;
    background: var(--accent);
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    border-radius: 100px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .event-book-btn:hover { opacity: 0.85; }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  ScrollTrigger.create({
    trigger: '[data-chat-text]',
    start: 'top 80%',
    once: true,
    onEnter: () => {
      gsap.to('[data-chat-text]', { opacity: 1, x: 0, duration: 0.9, ease: 'power2.out' })
    },
  })

  ScrollTrigger.create({
    trigger: '[data-chat-window]',
    start: 'top 80%',
    once: true,
    onEnter: () => {
      gsap.to('[data-chat-window]', { opacity: 1, x: 0, duration: 0.9, ease: 'power2.out', delay: 0.1 })

      document.querySelectorAll('[data-msg]').forEach((msg, i) => {
        gsap.to(msg, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out', delay: 0.4 + i * 0.2 })
      })
    },
  })
</script>
