---
---
<section class="how" id="how">
  <div class="container">
    <div class="section-header">
      <span class="section-label">How it works</span>
      <h2 class="section-title">Three messages. Done.</h2>
    </div>

    <ol class="steps">
      <li class="step" data-step>
        <span class="step-num">01</span>
        <div class="step-content">
          <h3 class="step-title">Share your location</h3>
          <p class="step-body">Drop a pin. That's all Tiximo needs to start looking.</p>
        </div>
      </li>

      <li class="step" data-step>
        <span class="step-num">02</span>
        <div class="step-content">
          <h3 class="step-title">Get a shortlist</h3>
          <p class="step-body">It pulls from Ticketmaster + Eventbrite, picks the good stuff, writes the pitch itself.</p>
        </div>
      </li>

      <li class="step" data-step>
        <span class="step-num">03</span>
        <div class="step-content">
          <h3 class="step-title">One tap to book</h3>
          <p class="step-body">Straight to checkout. You never leave the chat.</p>
        </div>
      </li>
    </ol>
  </div>
</section>

<style>
  .how {
    background: var(--bg);
    padding: 160px 0;
  }

  .section-header {
    margin-bottom: 80px;
  }

  .steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step {
    display: flex;
    align-items: baseline;
    gap: 32px;
    padding: 40px 0;
    border-top: 1px solid var(--border);
    opacity: 0;
    transform: translateY(24px);
  }

  .step:last-child {
    border-bottom: 1px solid var(--border);
  }

  .step-num {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 1px;
    flex-shrink: 0;
    width: 40px;
  }

  .step-content {
    flex: 1;
  }

  .step-title {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.5px;
    margin-bottom: 8px;
  }

  .step-body {
    font-size: 16px;
    color: var(--dim);
    line-height: 1.6;
    max-width: 480px;
  }

  @media (max-width: 600px) {
    .step { gap: 20px; padding: 32px 0; }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  gsap.utils.toArray<HTMLElement>('[data-step]').forEach((el, i) => {
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power2.out',
      delay: i * 0.1,
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        once: true,
      },
    })
  })
</script>
